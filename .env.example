# ============================================================================
# Pontus Property Tax Checker — environment template
# Copy to .env.local (web app) — the worker reads the repo-root .env file.
# NEVER commit real values.
# ============================================================================

# ---- Firebase Web config (CLIENT — safe to expose, controlled by rules) ----
# Firebase console → Project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (SERVER ONLY — a real secret) ---------------------------
# Project settings → Service accounts → Generate new private key. EITHER:
#   (a) local dev: save the file as ./serviceAccount.json (gitignored) and
#       point at it —
FIREBASE_SERVICE_ACCOUNT_KEY_FILE=./serviceAccount.json
#   (b) Vercel (no filesystem): paste the ENTIRE JSON as one line —
#       generate it with:  node -e "console.log(JSON.stringify(require('./serviceAccount.json')))" | pbcopy
FIREBASE_SERVICE_ACCOUNT_KEY=
# Bucket name (new projects: <project>.firebasestorage.app; older: .appspot.com)
FIREBASE_STORAGE_BUCKET=

# ---- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional access control for API routes (comma lists). Empty = any signed-in
# Google account this Firebase project's Auth accepts.
ALLOWED_EMAIL_DOMAINS=
ALLOWED_EMAILS=

# ---- Cloud Run worker trigger (production) -----------------------------------
# Leave empty in local dev — runs stay "queued" and you start the worker by
# hand: cd worker && python main.py --run-id <id>
CLOUD_RUN_JOB=tax-checker-worker
CLOUD_RUN_REGION=us-west1
# CLOUD_RUN_PROJECT= (defaults to the service account's project)

# ============================================================================
# Worker (cd worker && python main.py …) — reads repo-root .env too
# ============================================================================
SKYVERN_API_KEY=
# Optional Claude adjudication layer for fuzzy owner/address tie-breaks
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Same bucket as FIREBASE_STORAGE_BUCKET (worker-side name)
STORAGE_BUCKET=

# Tuning (defaults shown)
# SKYVERN_ENGINE=skyvern-2.0
# SKYVERN_MAX_STEPS=25
# SKYVERN_PROXY_LOCATION=RESIDENTIAL
# SKYVERN_ATTEMPT_TIMEOUT=900
# POLITE_DELAY_SECONDS=8
# MAX_CONCURRENCY=2
# MAX_ATTEMPTS_PER_ACCOUNT=3
